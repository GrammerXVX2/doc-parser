{
  "case_id": "ru_txt_basic",
  "format": "txt",
  "language": "ru",
  "description": "Базовый TXT-документ на русском языке.",
  "expected": {
    "min_pages": 1,
    "min_elements": 1,
    "must_contain_text": ["Пример"],
    "must_have_element_types": ["paragraph"],
    "must_have_chunks": true,
    "max_errors": 0
  },
  "tolerances": {
    "ignore_fields": ["document_id", "job_id", "processed_at", "duration_ms", "asset_id", "path"]
  }
}
