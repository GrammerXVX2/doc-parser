{
  "case_id": "ru_markdown_basic",
  "format": "markdown",
  "language": "ru",
  "description": "Базовый Markdown-документ на русском языке.",
  "expected": {
    "min_pages": 1,
    "min_elements": 2,
    "must_contain_text": ["Пример"],
    "must_have_element_types": ["heading", "text"],
    "must_have_chunks": true,
    "max_errors": 0
  },
  "tolerances": {
    "ignore_fields": ["document_id", "job_id", "processed_at", "duration_ms", "asset_id", "path"]
  }
}
